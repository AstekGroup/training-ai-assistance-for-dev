{
  "name": "@astek-pulse/meetup-deck",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Deck React + Vite + TypeScript + Shadcn UI pour Astek Pulse Meetup. Bootstrappé via le skill create-astek-pulse-meetup.",
  "keywords": [
    "astek",
    "pulse",
    "meetup",
    "react",
    "vite",
    "shadcn-ui"
